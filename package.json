{
  "name": "iett-bus-site",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "scripts": {
    "dev": "bun run watch:frontend & bun run dev:backend",
    "dev:backend": "bun run backend/server.ts",
    "build:frontend": "bun build frontend/src/script.ts --outfile frontend/dist/script.js --target=browser",
    "watch:frontend": "bun build frontend/src/script.ts --outfile frontend/dist/script.js --target=browser --watch",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
